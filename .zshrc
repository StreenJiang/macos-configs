#
# Input/output
#
bindkey -v

function zle-keymap-select {
	if [[ ${KEYMAP} == vicmd ]] || [[ $1 = 'block' ]]; then
		echo -ne '\e[1 q'
	elif [[ ${KEYMAP} == main ]] || [[ ${KEYMAP} == viins ]] || [[ ${KEYMAP} = '' ]] || [[ $1 = 'beam' ]]; then
		echo -ne '\e[5 q'
  fi
}
zle -N zle-keymap-select

# Use beam shape cursor on startup.
echo -ne '\e[5 q'

# Use beam shape cursor for each new prompt.
preexec() {
	echo -ne '\e[5 q'
}

_fix_cursor() {
	echo -ne '\e[5 q'
}
precmd_functions+=(_fix_cursor)

KEYTIMEOUT=1


# Flutter
export PATH=/Users/streen/SDKs/flutter/bin:$PATH
export PUB_HOSTED_URL=https://pub.flutter-io.cn
export FLUTTER_STORAGE_BASE_URL=https://storage.flutter-io.cn

# Dotnet
export PATH="/opt/homebrew/opt/dotnet@6/bin:$PATH"
alias showjdk='/usr/libexec/java_home -V'

# Homebrew
## 告诉 Homebrew 使用阿里云的源来更新自身
export HOMEBREW_BREW_GIT_REMOTE="https://mirrors.aliyun.com/homebrew/brew.git"
# 告诉 Homebrew 从阿里云的 API 获取包信息（这是 4.0 版本后的关键！）
export HOMEBREW_API_DOMAIN="https://mirrors.aliyun.com/homebrew-bottles/api"
# 告诉 Homebrew 从阿里云下载预编译的二进制包
export HOMEBREW_BOTTLE_DOMAIN="https://mirrors.aliyun.com/homebrew-bottles/bottles"

# JEnv
export PATH="$HOME/.jenv/bin:$PATH"
eval "$(jenv init -)"


. "$HOME/.local/bin/env"
